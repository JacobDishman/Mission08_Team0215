                                                <button type="submit" class="btn btn-sm btn-outline-success w-100">Done</button>
                                            </form>
                                            <form method="post" asp-action="Delete" asp-route-id="@task.TaskItemId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                                        onclick="return confirm('Delete \'@task.TaskName\'?');">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant IV: Not Important / Not Urgent -->
        <div class="col-md-6">
            <div class="card border-secondary h-100">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">Quadrant IV &mdash; Not Important / Not Urgent</h4>
                </div>
                <div class="card-body">
