                                            </form>
                                            <form method="post" asp-action="Delete" asp-route-id="@task.TaskItemId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                                        onclick="return confirm('Delete \'@task.TaskName\'?');">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
